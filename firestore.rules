rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isValidFolder(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.parentId is string && data.userId == request.auth.uid;
    }
    function isValidHtmlFile(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.content is string && data.content.size() < 1000000 && // 1MB limit
             data.folderId is string && data.userId == request.auth.uid &&
             data.createdAt is string;
    }

    match /folders/{folderId} {
      allow read, write: if true;
    }

    match /htmlFiles/{fileId} {
      allow read, write: if true;
    }
  }
}
